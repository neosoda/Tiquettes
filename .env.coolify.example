# ============================================================
# Vpanel Configuration for Coolify Deployment
# ============================================================
# Copy this file to .env.coolify and set values for your deployment
# These values control how Vpanel is built and deployed
# ============================================================

# CRITICAL: Set these BEFORE deploying to Coolify
# These are BUILD-TIME variables (baked into the app bundle)

# Your production domain
VITE_APP_URL=https://vpanel.example.com/
VITE_APP_HOSTNAME=https://vpanel.example.com
VITE_APP_BASE=/

# API endpoint (usually same domain with /api/ path)
VITE_APP_API_URL=https://vpanel.example.com/api/

# Locale and timezone
VITE_APP_LOCALE=fr-FR
VITE_APP_LOCALES=fr-FR,en-US

# Authentication (true = ask for password, false = public)
VITE_USE_AUTH=false

# ============================================================
# RUNTIME CONFIGURATION (can be changed without rebuild)
# Set these in Coolify environment variables
# ============================================================

# PHP-FPM worker processes (adjust based on CPU cores)
PHP_FPM_PM_MAX_CHILDREN=20
PHP_FPM_PM_START_SERVERS=4
PHP_FPM_PM_MIN_SPARE_SERVERS=2
PHP_FPM_PM_MAX_SPARE_SERVERS=10

# Default project settings (user preferences)
VITE_DEFAULT_PROJECT_NAME=Nouveau projet
VITE_DEFAULT_VREF=230
VITE_DEFAULT_ROWS=4
VITE_DEFAULT_STEPSPERROW=13

# Autosave settings
VITE_PROJECTS_AUTOSAVE_MINUTES=2
VITE_AUTOLOGOUT_TIMEOUT=10

# ============================================================
# INSTRUCTIONS
# ============================================================
# 1. Copy this file: cp .env.coolify.example .env.coolify
# 2. Edit .env.coolify with YOUR values
# 3. In Coolify Dashboard:
#    - Go to Application > Environment Variables
#    - Add Build Arguments from VITE_* variables above
#    - Add Runtime Environment from PHP_FPM_* variables
# 4. Deploy with: docker-compose -f docker-compose.prod.yml up
