# Version control
.git
.gitignore
.gitattributes

# Dependencies
node_modules
npm-debug.log
package-lock.json
yarn.lock

# Build artifacts (will be created during Docker build)
dist
build

# Environment files (security - never include in image)
.env
.env.local
.env.*.local
.env.production

# IDE and editor files
.vscode
.idea
.code-workspace
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Documentation and config (not needed in runtime)
README.md
CLAUDE.md
API.md
CHANGELOG.md
docs/
.cursor/
.github/
claude/
DEPLOYMENT_CHECKLIST.md

# Test files and coverage
*.test.js
*.spec.js
__tests__
coverage
.nyc_output

# Temporary files
*.log
*.tmp
*.swp
temp/
tmp/

# Dev-only tools (not needed in final image, but required for build)
.prettierrc
test-deploy.sh

# Docker files (not needed in image)
Dockerfile
docker-compose.yml
docker-compose.prod.yml
.dockerignore
